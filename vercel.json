{
  "version": 2,
  "framework": null,
  "buildCommand": "mkdir -p public && cp -f index.html styles.css app.js browser-client.js charset.json public/ && if [ -d Speech ]; then cp -r Speech public/; fi && if [ -f CNAME ]; then cp -f CNAME public/; fi",
  "outputDirectory": "public",
  "installCommand": "echo skip",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/(app|browser-client|styles).(js|css)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=120" }
      ]
    }
  ]
}
